{
  "name": "pastors-protocol-central",
  "private": true,
  "version": "1.0.0",
  "description": "Pastors' Protocol Central Sitting Arrangement — Dignitary Seating Management System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run --config ./vitest.config.js --configLoader runner",
    "test:frontend": "vitest run --config ./vitest.config.js --configLoader runner",
    "test:backend": "powershell -Command \"Set-Location './backend'; if (!(Test-Path './.tmp')) { New-Item -ItemType Directory -Path './.tmp' | Out-Null }; $env:TMP=(Resolve-Path './.tmp'); $env:TEMP=$env:TMP; & ./.venv/Scripts/python.exe -m pytest -q --capture=no\"",
    "test:all": "npm run test:frontend && npm run test:backend"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsdom": "^29.1.1",
    "vite": "^5.3.4",
    "vitest": "^4.1.6"
  }
}
